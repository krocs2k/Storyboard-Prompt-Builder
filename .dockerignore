# Dependencies (will be installed fresh in Docker)
node_modules

# Build outputs
.next
.build
out
dist
build

# Lock files (symlinked in dev environment)
yarn.lock
package-lock.json

# Environment files (provided at runtime)
.env
.env.*
!.env.example

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Documentation (keep README)
*.md
!README.md

# OS files
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Deployment reference files
DEEP-AGENT-*.md
DEEP-AGENT-*.pdf
DOCKER-DEPLOY.*

# Test and coverage
coverage
.nyc_output

# Abacus.AI specific
.abacus.donotdelete
.deploy

# IMPORTANT: Do NOT ignore these — needed for Docker builds:
