generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/storyboard_prompt_builder/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Authentication models
model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  role            String          @default("user") // "user" or "admin"
  isActive        Boolean         @default(false) // Disabled by default, admin must enable
  accounts        Account[]
  sessions        Session[]
  savedPrompts    SavedPrompt[]
  projectFolders  ProjectFolder[]
  projects        Project[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("email") // "email" or "password_reset"

  @@unique([identifier, token])
}

// System configuration for dynamic settings like Google SSO
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedPrompt {
  id          String   @id @default(cuid())
  name        String
  prompt      String   @db.Text
  selections  Json
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectFolder {
  id          String    @id @default(cuid())
  name        String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id              String         @id @default(cuid())
  name            String
  folderId        String?
  folder          ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenplay      Screenplay?
  storyboard      Storyboard?
  selections      Json?
  recommendations Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Screenplay {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title               String
  runtime             Int
  content             String   @db.Text
  characters          Json
  environments        Json
  sourceType          String
  sourceUrl           String?
  storyIdea           String?  @db.Text
  characterPrompts    Json?
  environmentPrompts  Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Storyboard {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks            Json
  shotlist          Json
  totalBlocks       Int
  estimatedRuntime  Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
