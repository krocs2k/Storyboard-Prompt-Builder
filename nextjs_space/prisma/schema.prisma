generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/storyboard_prompt_builder/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model SavedPrompt {
  id          String   @id @default(cuid())
  name        String
  prompt      String   @db.Text
  selections  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectFolder {
  id          String    @id @default(cuid())
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id              String         @id @default(cuid())
  name            String
  folderId        String?
  folder          ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  screenplay      Screenplay?
  storyboard      Storyboard?
  selections      Json?
  recommendations Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Screenplay {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title               String
  runtime             Int
  content             String   @db.Text
  characters          Json
  environments        Json
  sourceType          String
  sourceUrl           String?
  storyIdea           String?  @db.Text
  characterPrompts    Json?
  environmentPrompts  Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Storyboard {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks            Json
  shotlist          Json
  totalBlocks       Int
  estimatedRuntime  Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
